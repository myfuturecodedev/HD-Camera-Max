<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top Action Menu Bar Overlay Element -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clTopBar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_52sdp"
        android:background="#99000000"
        android:paddingHorizontal="@dimen/_14sdp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnSettings"
            android:layout_width="@dimen/_22sdp"
            android:layout_height="@dimen/_22sdp"
            android:src="@drawable/ic_settings"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <ImageView
            android:id="@+id/btnFlash"
            android:layout_width="@dimen/_22sdp"
            android:layout_height="@dimen/_22sdp"
            android:src="@drawable/ic_flash_off"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnSettings"
            app:layout_constraintEnd_toStartOf="@id/btnSwitchCamera" />

        <ImageView
            android:id="@+id/btnSwitchCamera"
            android:layout_width="@dimen/_22sdp"
            android:layout_height="@dimen/_22sdp"
            android:src="@drawable/ic_switch_camera"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Center Zoom Level Indicators Row Section -->
    <LinearLayout
        android:id="@+id/llZoomLevelPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_rounded_control_panel"
        android:paddingHorizontal="@dimen/_12sdp"
        android:paddingVertical="@dimen/_6sdp"
        android:layout_marginBottom="@dimen/_14sdp"
        app:layout_constraintBottom_toTopOf="@id/clBottomControls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvZoom1x"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1x"
            android:textColor="@color/accent_yellow"
            android:textSize="@dimen/_11ssp"
            android:textStyle="bold"
            android:paddingHorizontal="@dimen/_10sdp"/>

        <TextView
            android:id="@+id/tvZoom10x"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10x"
            android:textColor="@color/text_white"
            android:textSize="@dimen/_11ssp"
            android:paddingHorizontal="@dimen/_10sdp"/>

        <TextView
            android:id="@+id/tvZoom100x"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="100x"
            android:textColor="@color/text_white"
            android:textSize="@dimen/_11ssp"
            android:paddingHorizontal="@dimen/_10sdp"/>

    </LinearLayout>

    <!-- Main Shutter Control Panel Box Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clBottomControls"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_125sdp"
        android:background="#B3000000"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/llModeSelectionTabs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/_8sdp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VIDEO"
                android:textColor="@color/text_gray_dim"
                android:textSize="@dimen/_11ssp"
                android:layout_marginHorizontal="@dimen/_14sdp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PHOTO"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:textSize="@dimen/_11ssp"
                android:layout_marginHorizontal="@dimen/_14sdp"/>

        </LinearLayout>

        <ImageView
            android:id="@+id/btnGallery"
            android:layout_width="@dimen/_38sdp"
            android:layout_height="@dimen/_38sdp"
            android:src="@drawable/ic_gallery_thumb_frame"
            android:scaleType="centerCrop"
            android:layout_marginStart="@dimen/_24sdp"
            app:layout_constraintTop_toTopOf="@id/btnShutterAction"
            app:layout_constraintBottom_toBottomOf="@id/btnShutterAction"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/btnShutterAction"
            android:layout_width="@dimen/_58sdp"
            android:layout_height="@dimen/_58sdp"
            android:src="@drawable/ic_camera_shutter_trigger"
            android:layout_marginTop="@dimen/_8sdp"
            app:layout_constraintTop_toBottomOf="@id/llModeSelectionTabs"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/btnFiltersPanel"
            android:layout_width="@dimen/_28sdp"
            android:layout_height="@dimen/_28sdp"
            android:src="@drawable/ic_live_effects_filter"
            android:layout_marginEnd="@dimen/_24sdp"
            app:layout_constraintTop_toTopOf="@id/btnShutterAction"
            app:layout_constraintBottom_toBottomOf="@id/btnShutterAction"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>