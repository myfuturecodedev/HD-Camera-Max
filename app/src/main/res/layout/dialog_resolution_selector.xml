<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_camera_resolution_sheet"
    android:padding="@dimen/_16sdp"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

    <View
        android:id="@+id/viewHeaderNotch"
        android:layout_width="@dimen/_36sdp"
        android:layout_height="@dimen/_4sdp"
        android:background="@drawable/bg_camera_sheet_notch"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvResolutionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_14sdp"
        android:text="@string/photo_resolution"
        android:textColor="@color/text_dark_primary"
        android:textSize="@dimen/_16ssp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/viewHeaderNotch" />

    <TextView
        android:id="@+id/tvResolutionSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_4sdp"
        android:text="@string/choose_image_quality_and_aspect_ratio"
        android:textColor="@color/text_gray_dim"
        android:textSize="@dimen/_9ssp"
        app:layout_constraintEnd_toStartOf="@id/btnCloseDialog"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvResolutionTitle" />

    <ImageView
        android:id="@+id/btnCloseDialog"
        android:layout_width="@dimen/_28sdp"
        android:layout_height="@dimen/_28sdp"
        android:layout_marginTop="@dimen/_12sdp"
        android:background="@drawable/bg_circle_icon"
        android:padding="@dimen/_8sdp"
        android:src="@drawable/ic_close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/viewHeaderNotch"
        app:tint="@color/text_dark_primary" />

    <LinearLayout
        android:id="@+id/ratioTabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_12sdp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tvResolutionSubtitle">

        <TextView
            android:id="@+id/btnRatioAll"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/_30sdp"
            android:layout_marginEnd="@dimen/_6sdp"
            android:background="@drawable/bg_camera_mode_active"
            android:gravity="center"
            android:paddingHorizontal="@dimen/_14sdp"
            android:text="@string/all"
            android:textColor="@color/white"
            android:textSize="@dimen/_9ssp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnRatio43"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/_30sdp"
            android:layout_marginEnd="@dimen/_6sdp"
            android:background="@drawable/bg_camera_resolution_filter"
            android:gravity="center"
            android:paddingHorizontal="@dimen/_14sdp"
            android:text="4:3"
            android:textColor="@color/text_dark_primary"
            android:textSize="@dimen/_9ssp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnRatio169"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/_30sdp"
            android:background="@drawable/bg_camera_resolution_filter"
            android:gravity="center"
            android:paddingHorizontal="@dimen/_14sdp"
            android:text="16:9"
            android:textColor="@color/text_dark_primary"
            android:textSize="@dimen/_9ssp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnRatio11"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/_30sdp"
            android:layout_marginStart="@dimen/_6sdp"
            android:background="@drawable/bg_camera_resolution_filter"
            android:gravity="center"
            android:paddingHorizontal="@dimen/_14sdp"
            android:text="1:1"
            android:textColor="@color/text_dark_primary"
            android:textSize="@dimen/_9ssp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnRatioRecommended"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/_30sdp"
            android:layout_marginStart="@dimen/_6sdp"
            android:background="@drawable/bg_camera_resolution_filter"
            android:gravity="center"
            android:paddingHorizontal="@dimen/_14sdp"
            android:text="@string/recommended"
            android:textColor="@color/text_dark_primary"
            android:textSize="@dimen/_9ssp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvResolutions"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_520sdp"
        android:layout_marginTop="@dimen/_12sdp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="@dimen/_8sdp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ratioTabs" />
</androidx.constraintlayout.widget.ConstraintLayout>
