<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ui.afterlogin.DashboardFragment">

    <ScrollView
        android:id="@+id/dashboardScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/_20sdp"
            android:paddingTop="@dimen/_44sdp"
            android:paddingEnd="@dimen/_20sdp"
            android:paddingBottom="@dimen/_118sdp">

            <!-- Header Section -->
            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/welcome_back"
                android:textColor="@color/dashboard_mint"
                android:textSize="@dimen/_14ssp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/ivAppLogo"
                android:layout_width="@dimen/_38sdp"
                android:layout_height="@dimen/_38sdp"
                android:layout_marginTop="@dimen/_6sdp"
                android:contentDescription="@null"
                android:src="@drawable/logo_small"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvWelcome" />

            <TextView
                android:id="@+id/tvAppName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_8sdp"
                android:fontFamily="sans-serif-black"
                android:text="HD Camera "
                android:textColor="@color/dashboard_title"
                android:textSize="@dimen/_24ssp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/ivAppLogo"
                app:layout_constraintStart_toEndOf="@id/ivAppLogo"
                app:layout_constraintTop_toTopOf="@id/ivAppLogo" />

            <TextView
                android:id="@+id/tvAppNameMax"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="Max"
                android:textColor="@color/dashboard_mint"
                android:textSize="@dimen/_24ssp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/tvAppName"
                app:layout_constraintStart_toEndOf="@id/tvAppName"
                app:layout_constraintTop_toTopOf="@id/tvAppName" />

            <TextView
                android:id="@+id/tvAppDesc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_2sdp"
                android:text="@string/dashboard_desc"
                android:textColor="@color/dashboard_body"
                android:textSize="@dimen/_12ssp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ivAppLogo" />

            <ImageView
                android:id="@+id/btnSettings"
                android:layout_width="@dimen/_52sdp"
                android:layout_height="@dimen/_52sdp"
                android:background="@drawable/bg_dashboard_settings_button"
                android:contentDescription="@string/settings"
                android:elevation="@dimen/_3sdp"
                android:padding="@dimen/_12sdp"
                android:src="@drawable/ic_menu"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvWelcome" />

            <!-- Featured Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvTakePhoto"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_196sdp"
                android:layout_marginTop="@dimen/_24sdp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="@dimen/_24sdp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@id/tvAppDesc">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_dashboard_hero_gradient"
                    android:clipToPadding="false"
                    android:paddingStart="@dimen/_20sdp"
                    android:paddingTop="@dimen/_24sdp"
                    android:paddingEnd="@dimen/_10sdp"
                    android:paddingBottom="@dimen/_22sdp">

                    <TextView
                        android:id="@+id/tvPrimaryAction"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_dashboard_primary_action"
                        android:paddingStart="@dimen/_14sdp"
                        android:paddingTop="@dimen/_6sdp"
                        android:paddingEnd="@dimen/_14sdp"
                        android:paddingBottom="@dimen/_6sdp"
                        android:text="@string/primary_action"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_11ssp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvTakePhotoTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_12sdp"
                        android:fontFamily="sans-serif-black"
                        android:text="@string/take_photo"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_24ssp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="@id/tvPrimaryAction"
                        app:layout_constraintTop_toBottomOf="@id/tvPrimaryAction" />

                    <TextView
                        android:id="@+id/tvTakePhotoDesc"
                        android:layout_width="@dimen/_135sdp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_8sdp"
                        android:lineSpacingExtra="@dimen/_2sdp"
                        android:text="@string/take_photo_desc"
                        android:textColor="#E8FFFFFF"
                        android:textSize="@dimen/_13ssp"
                        app:layout_constraintStart_toStartOf="@id/tvTakePhotoTitle"
                        app:layout_constraintTop_toBottomOf="@id/tvTakePhotoTitle" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnOpenCamera"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/_42sdp"
                        android:layout_marginTop="@dimen/_18sdp"
                        android:background="@drawable/bg_dashboard_open_camera"
                        android:drawableStart="@drawable/ic_camera_header"
                        android:drawablePadding="@dimen/_8sdp"
                        android:paddingStart="@dimen/_18sdp"
                        android:paddingEnd="@dimen/_18sdp"
                        android:text="@string/open_camera"
                        android:textAllCaps="false"
                        android:textColor="@color/dashboard_mint_dark"
                        android:textSize="@dimen/_11ssp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="@id/tvTakePhotoDesc"
                        app:layout_constraintTop_toBottomOf="@id/tvTakePhotoDesc" />

                    <ImageView
                        android:id="@+id/ivHeroCamera"
                        android:layout_width="@dimen/_176sdp"
                        android:layout_height="@dimen/_150sdp"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter"
                        android:src="@drawable/camera_logo"
                        android:translationX="@dimen/_6sdp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Quick Tools -->
            <TextView
                android:id="@+id/tvQuickTools"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_28sdp"
                android:fontFamily="sans-serif-black"
                android:text="@string/quick_tools"
                android:textColor="@color/dashboard_title"
                android:textSize="@dimen/_17ssp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cvTakePhoto" />

            <TextView
                android:id="@+id/tvSeeAllTools"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/see_all"
                android:textColor="@color/dashboard_mint"
                android:textSize="@dimen/_12ssp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/tvQuickTools"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvQuickTools" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvGallery"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_132sdp"
                android:layout_marginTop="@dimen/_16sdp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/_24sdp"
                app:cardElevation="@dimen/_4sdp"
                app:strokeColor="@color/dashboard_card_stroke"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/tvQuickTools">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingStart="@dimen/_18sdp"
                    android:paddingEnd="@dimen/_12sdp">

                    <TextView
                        android:id="@+id/tvGalleryTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="@string/my_gallery"
                        android:textColor="@color/dashboard_title"
                        android:textSize="@dimen/_20ssp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toTopOf="@id/tvGalleryDesc"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintVertical_chainStyle="packed" />

                    <TextView
                        android:id="@+id/tvGalleryDesc"
                        android:layout_width="@dimen/_125sdp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:lineSpacingExtra="@dimen/_1sdp"
                        android:text="@string/my_gallery_desc"
                        android:textColor="@color/dashboard_body"
                        android:textSize="@dimen/_13ssp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="@id/tvGalleryTitle"
                        app:layout_constraintTop_toBottomOf="@id/tvGalleryTitle" />

                    <View
                        android:id="@+id/viewGalleryGlow"
                        android:layout_width="@dimen/_112sdp"
                        android:layout_height="@dimen/_112sdp"
                        android:background="@drawable/bg_dashboard_gallery_glow"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <ImageView
                        android:id="@+id/ivGalleryArt"
                        android:layout_width="@dimen/_160sdp"
                        android:layout_height="@dimen/_116sdp"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_gallerys"
                        android:translationX="@dimen/_4sdp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Camera Features -->
            <TextView
                android:id="@+id/tvCameraFeatures"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_26sdp"
                android:fontFamily="sans-serif-black"
                android:text="@string/camera_features"
                android:textColor="@color/dashboard_title"
                android:textSize="@dimen/_17ssp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cvGallery" />

            <LinearLayout
                android:id="@+id/llFeatures"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_14sdp"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/tvCameraFeatures">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/_58sdp"
                        android:layout_height="@dimen/_58sdp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_search" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:text="@string/hd_zoom"
                        android:textColor="@color/dashboard_label"
                        android:textSize="@dimen/_11ssp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/_58sdp"
                        android:layout_height="@dimen/_58sdp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_portait" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:text="@string/portrait"
                        android:textColor="@color/dashboard_label"
                        android:textSize="@dimen/_11ssp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/_58sdp"
                        android:layout_height="@dimen/_58sdp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_filter" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:text="@string/filters"
                        android:textColor="@color/dashboard_label"
                        android:textSize="@dimen/_11ssp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/_58sdp"
                        android:layout_height="@dimen/_58sdp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_beauty" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:text="@string/beauty"
                        android:textColor="@color/dashboard_label"
                        android:textSize="@dimen/_11ssp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Recent Photos -->
            <TextView
                android:id="@+id/tvRecentPhotos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_26sdp"
                android:fontFamily="sans-serif-black"
                android:text="@string/recent_photos"
                android:textColor="@color/dashboard_title"
                android:textSize="@dimen/_17ssp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/llFeatures" />

            <TextView
                android:id="@+id/tvViewAllPhotos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/view_all"
                android:textColor="@color/dashboard_mint"
                android:textSize="@dimen/_12ssp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/tvRecentPhotos"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvRecentPhotos" />

            <HorizontalScrollView
                android:id="@+id/recentPhotosScroll"
                android:layout_width="0dp"
                android:layout_height="@dimen/_100sdp"
                android:layout_marginTop="@dimen/_16sdp"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:scrollbars="none"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvRecentPhotos">

                <LinearLayout
                    android:id="@+id/recentPhotosRow"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/_92sdp"
                        android:layout_height="@dimen/_86sdp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="@dimen/_12sdp"
                        app:cardCornerRadius="@dimen/_12sdp"
                        app:cardElevation="@dimen/_2sdp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/ivRecentPhotoOne"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/recent_photos"
                            android:scaleType="centerCrop"
                            tools:src="@drawable/bg_dashboard_recent_placeholder" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/_92sdp"
                        android:layout_height="@dimen/_86sdp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="@dimen/_12sdp"
                        app:cardCornerRadius="@dimen/_12sdp"
                        app:cardElevation="@dimen/_2sdp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/ivRecentPhotoTwo"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/recent_photos"
                            android:scaleType="centerCrop"
                            tools:src="@drawable/bg_dashboard_recent_placeholder" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/_92sdp"
                        android:layout_height="@dimen/_86sdp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="@dimen/_12sdp"
                        app:cardCornerRadius="@dimen/_12sdp"
                        app:cardElevation="@dimen/_2sdp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/ivRecentPhotoThree"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/recent_photos"
                            android:scaleType="centerCrop"
                            tools:src="@drawable/bg_dashboard_recent_placeholder" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/_92sdp"
                        android:layout_height="@dimen/_86sdp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="@dimen/_12sdp"
                        app:cardCornerRadius="@dimen/_12sdp"
                        app:cardElevation="@dimen/_2sdp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/ivRecentPhotoFour"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/recent_photos"
                            android:scaleType="centerCrop"
                            tools:src="@drawable/bg_dashboard_recent_placeholder" />
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </HorizontalScrollView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Bottom Capture Button Container -->
    <LinearLayout
        android:id="@+id/captureDock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/_22sdp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/fabCapture"
            android:layout_width="@dimen/_78sdp"
            android:layout_height="@dimen/_78sdp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="@dimen/_39sdp"
            app:cardElevation="@dimen/_6sdp"
            app:strokeWidth="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="@dimen/_7sdp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_dashboard_capture_circle"
                    android:contentDescription="@string/capture"
                    android:padding="@dimen/_18sdp"
                    android:src="@drawable/ic_camera_header"
                    app:tint="@color/white" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_8sdp"
            android:text="@string/capture"
            android:textColor="@color/dashboard_mint_dark"
            android:textSize="@dimen/_15ssp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
