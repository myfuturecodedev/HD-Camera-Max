<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Yellow ring -->
    <item>
        <shape android:shape="oval">
            <stroke android:width="4dp" android:color="#FFD214" />
            <size android:width="@dimen/_58sdp" android:height="@dimen/_58sdp" />
        </shape>
    </item>
    <!-- Inner clickable solid white circle -->
    <item android:top="8dp" android:bottom="8dp" android:left="8dp" android:right="8dp">
        <shape android:shape="oval">
            <solid android:color="#EBECEF" />
        </shape>
    </item>
</layer-list>